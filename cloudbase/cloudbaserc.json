{
  "envId": "REPLACE_WITH_YOUR_CLOUDBASE_ENV_ID",
  "version": "2.0",
  "framework": {
    "name": "looma-miniprogram",
    "plugins": {
      "function": {
        "use": "@cloudbase/framework-plugin-function",
        "inputs": {
          "functions": [
            {
              "name": "wechat-login",
              "config": {
                "runtime": "Nodejs16.13",
                "memorySize": 128,
                "timeout": 5
              }
            }
          ]
        }
      },
      "static": {
        "use": "@cloudbase/framework-plugin-static",
        "inputs": {
          "outputPath": "static"
        }
      }
    }
  }
}
