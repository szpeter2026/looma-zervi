# ---- 数据库（pgvector）----
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_password_here
PG_DATABASE=looma

# ---- Ollama ----
OLLAMA_HOST=http://127.0.0.1:11434
EMBED_MODEL=nomic-embed-text:latest
LLM_MODEL=ollama/qwen2.5-coder:1.5b

# ---- LlamaIndex ----
EMBED_DIM=768

# ---- 服务配置 ----
LOOMA_HOST=127.0.0.1
LOOMA_PORT=8010

# ---- 认证 ----
# AUTH_STUB=true（开发模式，任意 token 视为 free | false 需真实 JWT）
AUTH_STUB=true
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_JWT_SECRET=your_jwt_secret

# ---- 对象存储（P2 实现）----
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=looma-uploads

# ---- 地区定价 ----
# DEFAULT_REGION=CN（默认地区）
