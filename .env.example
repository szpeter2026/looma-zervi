# ──────────────────────────────────────────
#  Looma & Zervi — 环境变量配置
#  复制此文件为 .env 并修改对应值
# ──────────────────────────────────────────

# ── 数据库（pgvector）────────────────────
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_password_here
PG_DATABASE=looma

# ── Ollama（本地 LLM + Embedding）────────
OLLAMA_HOST=http://127.0.0.1:11434
EMBED_MODEL=nomic-embed-text:latest
LLM_MODEL=ollama/qwen2.5-coder:1.5b

# ── LLM Provider 优先级（逗号分隔，按优先级尝试）──
# 当主 LLM_MODEL 不可用时，自动按此顺序切换 provider
# 支持值："ollama", "deepseek", "openai"
# 例：LLM_PROVIDER_ORDER=deepseek,ollama,openai
LLM_PROVIDER_ORDER=ollama,deepseek,openai

# 可选：为每个 LLM provider 指定 model 名称（若未设置则使用 LLM_MODEL）
OLLAMA_MODEL=
DEEPSEEK_MODEL=
OPENAI_MODEL=

# ── Embedding Provider 优先级（独立于 LLM provider）──
# 支持值："ollama", "openai", "deepseek"
# 例：EMBED_PROVIDER_ORDER=openai,ollama,deepseek
EMBED_PROVIDER_ORDER=ollama,openai,deepseek

# 可选：为每个 embedding provider 指定 model 名称
#   ollama 使用 EMBED_MODEL
#   openai 默认 text-embedding-3-small（或 text-embedding-ada-002）
#   deepseek 默认 deepseek-chat
OPENAI_EMBED_MODEL=
DEEPSEEK_EMBED_MODEL=

# ── API Keys（按需配置，不配则跳过对应 provider）──
OPENAI_API_KEY=
OPENAI_BASE_URL=                # 可选：自定义 API 代理地址，如 https://api.openai.com/v1

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=              # 可选：默认 https://api.deepseek.com/v1

# ── 调用弹性策略（超时/重试/熔断）──────
# LLM 调用超时（秒），默认 120
LLM_CALL_TIMEOUT=120
# LLM 最大重试次数（不含首次调用），默认 2
LLM_MAX_RETRIES=2

# Embedding 调用超时（秒），默认 30
EMBED_CALL_TIMEOUT=30
# API 请求超时（秒），用于 /v1/ask 等端点的调用保护，默认 90
API_REQUEST_TIMEOUT=90
# Embedding 最大重试次数，默认 2
EMBED_MAX_RETRIES=2

# 熔断器配置（代码内固定）：
#   - 连续失败 5 次 → 熔断断开
#   - 冷却 30 秒 → 半开状态
#   - 半开状态下一次成功 → 恢复闭合

# ── LlamaIndex ───────────────────────────
EMBED_DIM=768

# ── 服务配置 ─────────────────────────────
LOOMA_HOST=127.0.0.1
LOOMA_PORT=8010

# ── 认证 ─────────────────────────────────
# AUTH_STUB=true（开发模式，任意 token 视为 free | false 需真实 JWT）
AUTH_STUB=true
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_JWT_SECRET=your_jwt_secret

# ── 对象存储（P2 实现）───────────────────
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=looma-uploads

# ── 地区定价 ─────────────────────────────
# DEFAULT_REGION=CN（默认地区）
