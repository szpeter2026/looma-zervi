# ============================================
# Looma Backend Environment Configuration
# ============================================
# Copy to .env and fill in real values

# --- Flask ---
FLASK_ENV=development
FLASK_PORT=5000
SECRET_KEY=change-me-to-a-random-string

# --- JWT Auth ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-to-a-secure-random-key
JWT_EXPIRY_HOURS=24
JWT_ALGORITHM=HS256

# --- WeChat MiniApp ---
# From WeChat MP console (mp.weixin.qq.com)
WECHAT_APPID=your-appid
WECHAT_APP_SECRET=your-app-secret

# --- DeepSeek API ---
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# --- ChromaDB ---
CHROMA_MODE=local          # local | remote
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=looma_knowledge

# --- SQLite ---
DATABASE_PATH=data/looma.db

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# --- Quota ---
FREE_DAILY_LIMIT=30
SUPPORTER_DAILY_LIMIT=999999
PRO_DAILY_LIMIT=999999

# --- CloudBase (miniprogram shell) ---
# Only needed for CloudBase cloud functions
CLOUDBASE_ENV_ID=your-cloudbase-env-id
