# ============================================
# Looma Backend Environment Configuration
# ============================================
# Copy to .env and fill in real values

# --- Flask ---
FLASK_ENV=development
FLASK_PORT=5000
SECRET_KEY=change-me-to-a-random-string

# --- JWT Auth ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-to-a-secure-random-key
JWT_EXPIRY_HOURS=24
JWT_ALGORITHM=HS256

# --- WeChat MiniApp ---
# From WeChat MP console (mp.weixin.qq.com)
WECHAT_APPID=your-appid
WECHAT_APP_SECRET=your-app-secret

# --- DeepSeek API ---
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# --- ChromaDB ---
CHROMA_MODE=local          # local | remote
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=looma_knowledge

# --- SQLite ---
DATABASE_PATH=data/looma.db

# --- CORS ---
# Dev: http://localhost:5173,http://localhost:5174,http://localhost:3000
# Production: https://szbolent.cn,https://www.szbolent.cn,https://api.szbolent.cn
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# --- Quota ---
FREE_DAILY_LIMIT=30
SUPPORTER_DAILY_LIMIT=999999
PRO_DAILY_LIMIT=999999

# --- LLM Provider (comma-separated, tried in order) ---
LLM_PROVIDER_ORDER=deepseek,ollama,openai
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# --- Embedding ---
EMBED_PROVIDER_ORDER=ollama,deepseek
EMBED_MODEL=nomic-embed-text:latest
EMBED_DIM=768

# --- API ---
API_REQUEST_TIMEOUT=90.0

# --- pgvector (optional — for RAG fallback) ---
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=looma

# --- Navigator Psychology ---
PSYCHOLOGY_ENABLED=true
PSYCHOLOGY_API_TYPE=local
SENTINO_API_KEY=

# --- CloudBase (miniprogram shell) ---
# Only needed for CloudBase cloud functions
CLOUDBASE_ENV_ID=your-cloudbase-env-id
