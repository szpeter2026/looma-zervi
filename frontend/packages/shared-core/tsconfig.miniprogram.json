{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../miniprogram/npm_modules/@looma/shared-core",
    "declaration": true,
    "declarationDir": "../miniprogram/npm_modules/@looma/shared-core/types",
    "module": "commonjs",
    "target": "es2015",
    "lib": ["es2015"],
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}