<wxs module="calc">
  function pct(xp, xpToNext) {
    if (!xpToNext || xpToNext <= 0) return 0;
    var v = (xp / xpToNext) * 100;
    return v > 100 ? 100 : v;
  }
  function rankName(level) {
    if (level <= 3) return '星际新兵';
    if (level <= 6) return '星域探索者';
    if (level <= 10) return '银河领航员';
    if (level <= 15) return '星际指挥官';
    return '宇宙传奇';
  }
  module.exports = { pct: pct, rankName: rankName };
</wxs>
<view class="xp-bar">
  <view class="xp-header">
    <text class="xp-label">⚡ 星际能量</text>
    <view class="xp-rank">
      🪐 Lv.{{level}} · {{calc.rankName(level)}}
    </view>
    <text class="xp-count">{{xp}} / {{xpToNext}} XP</text>
  </view>
  <view class="xp-track">
    <view class="xp-fill" style="width: {{calc.pct(xp, xpToNext)}}%;"></view>
  </view>
</view>
