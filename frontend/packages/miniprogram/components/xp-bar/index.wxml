<view class="xp-bar">
  <view class="xp-header">
    <text class="xp-label">⚡ 星际能量</text>
    <view class="xp-rank">
      🪐 Lv.{{level}} · {{rankName}}
    </view>
    <text class="xp-count">{{xp}} / {{xpToNext}} XP</text>
  </view>
  <view class="xp-track">
    <view class="xp-fill" style="width: {{pct}}%;"></view>
  </view>
</view>
