/* ============ Header ============ */
.header {
  text-align: center;
  padding: 48rpx 32rpx 32rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
}

.header-sub {
  font-size: 26rpx;
  color: #B8B8C8;
  margin-top: 12rpx;
}

.tier-highlight {
  color: #C8FF50;
  font-weight: 600;
}

.stub-badge {
  display: inline-block;
  margin-left: 12rpx;
  padding: 4rpx 16rpx;
  font-size: 20rpx;
  color: #FFA500;
  background: rgba(255, 165, 0, 0.15);
  border-radius: 8rpx;
  border: 1rpx solid rgba(255, 165, 0, 0.3);
}

/* ============ Loading ============ */
.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  gap: 24rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid rgba(200, 255, 80, 0.2);
  border-top-color: #C8FF50;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #B8B8C8;
}

/* ============ Plan Cards ============ */
.plans-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 0 24rpx;
}

.plan-card {
  position: relative;
  background: rgba(26, 26, 46, 0.8);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  overflow: hidden;
  transition: border-color 0.3s;
}

.plan-card.plan-current {
  border-color: rgba(200, 255, 80, 0.3);
  background: rgba(200, 255, 80, 0.04);
}

.plan-card.plan-pro {
  border-color: rgba(100, 180, 255, 0.3);
  background: rgba(100, 180, 255, 0.04);
}

/* Badges */
.current-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  font-size: 20rpx;
  color: #C8FF50;
  background: rgba(200, 255, 80, 0.12);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.pro-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  font-size: 20rpx;
  color: #64B4FF;
  background: rgba(100, 180, 255, 0.12);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

/* Plan Info */
.plan-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.plan-price {
  font-size: 48rpx;
  font-weight: bold;
  color: #C8FF50;
  margin-bottom: 24rpx;
}

.plan-pro .plan-price {
  color: #64B4FF;
}

/* Features */
.plan-features {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 32rpx;
}

.feature-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.feature-check {
  font-size: 24rpx;
  color: #C8FF50;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.feature-text {
  font-size: 24rpx;
  color: #D0D0E0;
  line-height: 1.5;
}

/* Buttons */
.plan-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  padding: 0;
}

.plan-btn::after {
  border: none;
}

.btn-disabled {
  background: rgba(255, 255, 255, 0.06) !important;
  color: #666 !important;
}

.btn-supporter {
  background: linear-gradient(135deg, #C8FF50, #A0E040);
  color: #0D0D1A;
}

.btn-pro {
  background: linear-gradient(135deg, #64B4FF, #4080E0);
  color: #ffffff;
}

/* ============ Footer ============ */
.footer {
  text-align: center;
  padding: 48rpx 32rpx 32rpx;
}

.footer-text {
  display: block;
  font-size: 22rpx;
  color: #666;
  line-height: 1.8;
}
