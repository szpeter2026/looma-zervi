/* ============ User Card ============ */
.user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.user-avatar {
  font-size: 80rpx;
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #1A1A2E;
  border: 2rpx solid rgba(200, 255, 80, 0.2);
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.user-tier {
  margin-top: 8rpx;
}

.early-badge {
  font-size: 22rpx;
  color: #FFD700;
  margin-top: 8rpx;
}

/* ============ Stats Card ============ */
.stats-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.stat-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.stat-key {
  font-size: 26rpx;
  color: #B8B8C8;
}

.stat-val {
  font-size: 26rpx;
  color: #C8FF50;
  font-weight: 600;
}

/* ============ Menu ============ */
.menu-card {
  padding: 0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #ffffff;
}

.menu-arrow {
  font-size: 32rpx;
  color: #B8B8C8;
}

/* ============ Logout ============ */
.logout-btn {
  text-align: center;
  padding: 24rpx;
  margin-top: 48rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  font-size: 26rpx;
  color: #B8B8C8;
  background: transparent;
}
