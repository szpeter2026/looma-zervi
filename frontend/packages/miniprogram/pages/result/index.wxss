.result-card {
  background: #0D0D1A;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 32rpx;
  padding: 48rpx 32rpx;
  text-align: center;
}

.result-emoji {
  font-size: 120rpx;
  margin-bottom: 16rpx;
}

.result-name {
  font-size: 40rpx;
  font-weight: 900;
  color: #C8FF50;
}

.result-tagline {
  font-size: 24rpx;
  color: #B8B8C8;
  letter-spacing: 2rpx;
  margin-top: 8rpx;
}

.traits-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: center;
  margin: 32rpx 0;
}

.trait-tag {
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  background: rgba(107, 63, 160, 0.2);
  color: #C4B5FD;
}

.result-desc {
  font-size: 28rpx;
  color: #B8B8C8;
  line-height: 1.7;
  margin-bottom: 32rpx;
  text-align: left;
}

/* ============ Share Preview ============ */
.share-preview {
  background: linear-gradient(135deg, #0D0D1A 0%, #1A0A2E 50%, #0A1A0A 100%);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 32rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 32rpx;
}

.preview-emoji {
  font-size: 96rpx;
}

.preview-name {
  font-size: 36rpx;
  font-weight: 900;
  color: #C8FF50;
  margin-top: 8rpx;
}

.preview-label {
  font-size: 24rpx;
  color: #B8B8C8;
  margin-top: 8rpx;
}

/* ============ Actions ============ */
.btn-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn-actions button {
  margin: 0;
  padding: 20rpx 0;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 24rpx;
  width: 100%;
  line-height: 1.6;
}

.btn-actions button::after {
  border: none;
}

/* ============ No Result ============ */
.no-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: 32rpx;
}

.no-result-icon {
  font-size: 120rpx;
}

.no-result-text {
  font-size: 28rpx;
  color: #B8B8C8;
}

.no-result .btn-primary {
  max-width: 400rpx;
}
