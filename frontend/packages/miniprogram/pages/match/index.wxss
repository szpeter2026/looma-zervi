.scan-panel,
.result-panel,
.error-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 48rpx;
}

.scan-orbit {
  position: relative;
  width: 220rpx;
  height: 220rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.scan-core {
  font-size: 72rpx;
  z-index: 2;
}

.scan-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 4rpx solid rgba(200, 255, 80, 0.35);
  border-top-color: #c8ff50;
  animation: spin 1.4s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.scan-title,
.error-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.scan-status {
  font-size: 28rpx;
  color: #c8ff50;
  margin-bottom: 12rpx;
}

.scan-hint,
.error-msg {
  font-size: 24rpx;
  color: #b8b8c8;
  text-align: center;
  padding: 0 32rpx;
  line-height: 1.5;
}

.result-label {
  font-size: 32rpx;
  font-weight: bold;
  color: #c8ff50;
  margin-bottom: 16rpx;
}

.fleet-chip {
  font-size: 22rpx;
  color: #b8b8c8;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 999rpx;
  padding: 8rpx 24rpx;
  margin-bottom: 40rpx;
}

.pair-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 100%;
  margin-bottom: 32rpx;
}

.pair-card {
  flex: 1;
  background: #0d0d1a;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 28rpx 16rpx;
  text-align: center;
}

.pair-emoji {
  font-size: 56rpx;
  margin-bottom: 8rpx;
}

.pair-role {
  font-size: 22rpx;
  color: #b8b8c8;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pair-type {
  font-size: 24rpx;
  font-weight: 600;
  color: #ffffff;
}

.pair-link {
  width: 120rpx;
  text-align: center;
  flex-shrink: 0;
}

.score {
  font-size: 44rpx;
  font-weight: 900;
  color: #c8ff50;
  line-height: 1;
}

.score-label {
  font-size: 20rpx;
  color: #b8b8c8;
  margin-top: 6rpx;
}

.reason-box {
  width: 100%;
  box-sizing: border-box;
  background: rgba(107, 63, 160, 0.2);
  border: 1rpx solid rgba(200, 255, 80, 0.2);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  font-size: 26rpx;
  color: #ffffff;
  line-height: 1.5;
  text-align: center;
  margin-bottom: 40rpx;
}

.btn-primary {
  width: 100%;
  box-sizing: border-box;
  text-align: center;
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: #c8ff50;
  color: #0a0a1a;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.btn-primary.disabled {
  opacity: 0.6;
}

.btn-ghost {
  width: 100%;
  box-sizing: border-box;
  text-align: center;
  padding: 20rpx;
  font-size: 26rpx;
  color: #b8b8c8;
}

.error-panel {
  padding-top: 80rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.error-msg {
  margin-bottom: 40rpx;
}
