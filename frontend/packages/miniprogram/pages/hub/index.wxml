<view class="page-container safe-bottom">
  <!-- Header -->
  <view class="hub-header">
    <view class="logo-text">Planet<text class="logo-x">X</text></view>
    <view class="identity-label" wx:if="{{identityLabel}}">{{identityLabel}}</view>
  </view>

  <!-- XP Bar -->
  <xp-bar level="{{level}}" xp="{{xp}}" xpToNext="{{xpToNext}}" />

  <!-- Internal Tabs -->
  <view class="tab-nav">
    <view class="tab-nav-item {{activeTab === 'missions' ? 'active' : ''}}" data-tab="missions" bindtap="switchTab">🎯 任务</view>
    <view class="tab-nav-item {{activeTab === 'team' ? 'active' : ''}}" data-tab="team" bindtap="switchTab">👥 舰队</view>
    <view class="tab-nav-item {{activeTab === 'profile' ? 'active' : ''}}" data-tab="profile" bindtap="switchTab">🪪 我的</view>
  </view>

  <!-- Missions Tab -->
  <view wx:if="{{activeTab === 'missions'}}" class="tab-content">
    <view
      wx:for="{{missions}}"
      wx:key="id"
      class="mission-card {{missionsCompleted.includes(item.id) ? 'done' : ''}}"
      data-id="{{item.id}}"
      bindtap="onMissionTap"
    >
      <view class="mission-icon">{{item.icon}}</view>
      <view class="mission-info">
        <view class="mission-name">{{item.name}}</view>
        <view class="mission-reward">🎁 {{item.reward}}</view>
      </view>
      <view class="mission-status">
        <text wx:if="{{missionsCompleted.includes(item.id)}}" class="status-done">已完成</text>
        <text wx:elif="{{item.requires && !missionsCompleted.includes(item.requires)}}" class="status-locked">🔒</text>
        <text wx:else class="status-todo">待完成</text>
      </view>
    </view>
  </view>

  <!-- Team Tab -->
  <view wx:elif="{{activeTab === 'team'}}" class="tab-content">
    <!-- No fleet -->
    <view wx:if="{{!fleet}}" class="card team-empty-card">
      <view class="team-icon-large">🚀</view>
      <view class="team-title">尚未组建舰队</view>
      <view class="team-desc">完成人格测试后可创建舰队，邀请好友加入</view>
      <view class="fleet-actions">
        <button class="btn-create" bindtap="onCreateFleetTap" loading="{{fleetCreating}}">🚀 创建舰队</button>
        <button class="btn-join" bindtap="showJoinFleetModal">🔗 加入舰队</button>
      </view>
    </view>

    <!-- Has fleet -->
    <view wx:else class="card fleet-detail-card">
      <view class="fleet-header">
        <view class="team-icon-large">🚀</view>
        <view class="fleet-name">{{fleet.name}}</view>
        <view class="fleet-member-count">舰队成员: {{teamSize}}/3</view>
      </view>

      <!-- Invite code section -->
      <view class="invite-section" bindtap="onCopyInviteCode">
        <view class="invite-label">舰队邀请码</view>
        <view class="invite-code">{{fleet.invite_code || '加载中...'}}</view>
        <view class="invite-hint">点击复制邀请码</view>
      </view>

      <!-- Member slots -->
      <view class="member-slots">
        <view class="member-slot filled">
          <view class="slot-avatar">🧑‍🚀</view>
          <view class="slot-name">我</view>
        </view>
        <view class="member-slot {{teamSize >= 2 ? 'filled' : ''}}">
          <view class="slot-avatar">{{teamSize >= 2 ? '🦊' : '❓'}}</view>
          <view class="slot-name">{{teamSize >= 2 ? '船员' : '虚位以待'}}</view>
        </view>
        <view class="member-slot {{teamSize >= 3 ? 'filled' : ''}}">
          <view class="slot-avatar">{{teamSize >= 3 ? '🐼' : '❓'}}</view>
          <view class="slot-name">{{teamSize >= 3 ? '船员' : '虚位以待'}}</view>
        </view>
      </view>

      <view class="fleet-actions">
        <button class="btn-create" bindtap="onCopyInviteCode">📋 复制邀请码</button>
      </view>
    </view>
  </view>

  <!-- Profile Tab -->
  <view wx:elif="{{activeTab === 'profile'}}" class="tab-content">
    <view class="card personality-card">
      <view class="personality-emoji">{{personalityEmoji || '🌌'}}</view>
      <view class="personality-name">{{personalityName || '未测试'}}</view>
      <view class="personality-tagline">{{personalityTagline || '完成人格测试获取你的星际身份'}}</view>
    </view>

    <view class="stats-grid">
      <view class="stat-card">
        <view class="stat-value">{{missionsCompleted.length}}</view>
        <view class="stat-label">完成任务</view>
      </view>
      <view class="stat-card">
        <view class="stat-value">{{teamSize}}</view>
        <view class="stat-label">舰队成员</view>
      </view>
      <view class="stat-card">
        <view class="stat-value">0</view>
        <view class="stat-label">信号传播</view>
      </view>
      <view class="stat-card">
        <view class="stat-value">{{xp}}</view>
        <view class="stat-label">总能量</view>
      </view>
    </view>
  </view>

  <!-- Join Fleet Modal -->
  <view wx:if="{{showFleetModal}}" class="modal-overlay" bindtap="hideJoinFleetModal">
    <view class="modal-content" catchtap="nohandle">
      <view class="modal-title">加入舰队</view>
      <input
        class="fleet-join-input"
        placeholder="输入舰队邀请码"
        value="{{fleetJoinCode}}"
        bindinput="onJoinCodeInput"
        auto-focus
      />
      <view class="modal-actions">
        <button class="btn-secondary" bindtap="hideJoinFleetModal">取消</button>
        <button class="btn-primary" bindtap="onJoinFleetConfirm" loading="{{fleetJoining}}">确认加入</button>
      </view>
    </view>
  </view>
</view>
