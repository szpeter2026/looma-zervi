<!-- pages/index/index.wxml -->
<view class="container">
  <view class="logo">PlanetX</view>
  <view class="slogan">你的职业飞行器</view>

  <view wx:if="{{loading}}" class="loading">登录中...</view>

  <view wx:elif="{{userInfo}}" class="welcome">
    <text>欢迎回来，{{userInfo.name || '探索者'}}</text>
    <view class="tier-badge">{{userInfo.tier}}</view>
  </view>

  <view wx:else class="login-btn" bindtap="handleLogin">
    微信登录
  </view>
</view>
