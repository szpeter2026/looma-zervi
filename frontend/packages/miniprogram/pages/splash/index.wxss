.splash-container {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 0 48rpx;
}

.splash-logo {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.loading-text {
  color: #B8B8C8;
  font-size: 26rpx;
  margin-top: 80rpx;
}

.login-failed {
  margin-top: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
  width: 100%;
}

.failed-text {
  color: #8888aa;
  font-size: 26rpx;
}

.login-failed .btn-primary {
  max-width: 400rpx;
}
