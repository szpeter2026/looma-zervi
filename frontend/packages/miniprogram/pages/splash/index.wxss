.splash-container {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 0 48rpx;
}

.splash-logo {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

/* Loading state */
.loading-area {
  margin-top: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(200, 255, 80, 0.2);
  border-top-color: #C8FF50;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  color: #B8B8C8;
  font-size: 26rpx;
}

/* Failed state */
.login-failed {
  margin-top: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  width: 100%;
  padding: 40rpx 32rpx;
  background: rgba(255, 60, 60, 0.08);
  border: 1rpx solid rgba(255, 60, 60, 0.2);
  border-radius: 16rpx;
}

.failed-icon {
  font-size: 48rpx;
}

.failed-text {
  color: #cc6666;
  font-size: 26rpx;
  text-align: center;
  line-height: 1.5;
}

.btn-primary {
  background: #C8FF50;
  color: #0a0a1a;
  font-size: 28rpx;
  font-weight: 600;
  padding: 20rpx 64rpx;
  border-radius: 44rpx;
  text-align: center;
}

.btn-skip {
  color: #8888aa;
  font-size: 24rpx;
  padding: 16rpx 32rpx;
  text-align: center;
  text-decoration: underline;
}
