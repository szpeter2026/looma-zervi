<star-bg />
<view class="page-container">
  <view class="auth-card">
    <view class="auth-icon">📧</view>
    <view class="auth-title">绑定邮箱</view>
    <view class="auth-desc">绑定后可在 Web 端同步使用\n跨平台数据互通</view>

    <view class="form-group">
      <input
        class="form-input"
        placeholder="邮箱地址"
        type="text"
        bindinput="onEmailInput"
        value="{{email}}"
      />
      <input
        class="form-input"
        placeholder="密码 (至少8位)"
        password="true"
        bindinput="onPasswordInput"
        value="{{password}}"
      />
    </view>

    <view class="btn-primary" bindtap="handleBind">绑定账号</view>
    <view class="btn-skip" bindtap="handleSkip">稍后再说</view>
  </view>
</view>
