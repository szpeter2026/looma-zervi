/* pages/auth/auth.wxss */
.container {
  padding: 40px 24px;
  background: #0a0a1a;
  min-height: 100vh;
  color: #e0e0ff;
}

.title {
  font-size: 24px;
  font-weight: 600;
  color: #6C63FF;
  margin-bottom: 8px;
}

.desc {
  font-size: 14px;
  color: #8888aa;
  margin-bottom: 32px;
}

.input {
  background: #1a1a2e;
  border: 1px solid #333355;
  border-radius: 12px;
  padding: 12px 16px;
  color: #e0e0ff;
  font-size: 16px;
  margin-bottom: 16px;
}

.btn {
  background: #6C63FF;
  color: white;
  text-align: center;
  padding: 12px;
  border-radius: 24px;
  font-size: 16px;
  margin-top: 16px;
}

.btn-secondary {
  text-align: center;
  padding: 12px;
  color: #8888aa;
  font-size: 14px;
  margin-top: 8px;
}
