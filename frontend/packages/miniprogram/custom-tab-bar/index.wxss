.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #0D0D1A;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0 16rpx;
  gap: 4rpx;
}

.tab-icon {
  font-size: 40rpx;
  line-height: 1;
}

.tab-text {
  font-size: 20rpx;
  color: #B8B8C8;
  font-weight: 500;
}

.tab-item.active .tab-text {
  color: #C8FF50;
  font-weight: 700;
}

.tab-item.active .tab-icon {
  transform: scale(1.1);
  transition: transform 0.2s;
}
