{
  "name": "looma-zervi-frontend",
  "private": true,
  "version": "0.1.0",
  "description": "Looma-Zervi frontend monorepo: PlanetX (C-end) + T-space (B-end)",
  "scripts": {
    "dev:planetx": "pnpm --filter @looma/planetx dev",
    "dev:saas": "pnpm --filter @looma/saas dev",
    "build:planetx": "pnpm --filter @looma/planetx build",
    "build:saas": "pnpm --filter @looma/saas build",
    "dev:genz-web": "pnpm --filter @looma/genz-web dev",
    "build:genz-web": "pnpm --filter @looma/genz-web build",
    "build:all": "pnpm --filter @looma/shared-core build && pnpm build:planetx && pnpm build:saas && pnpm build:genz-web",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:poetry": "playwright test e2e/poetry",
    "e2e:live": "playwright test --config=playwright.live.config.ts --project=live-saas",
    "e2e:live:all": "playwright test --config=playwright.live.config.ts",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "storybook": "^10.4.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  }
}
