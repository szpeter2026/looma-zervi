# Copy to backend/.env (same as repo root .env.example)
#   cp .env.example .env
#
# ============================================
# Looma Backend Environment Configuration
# ============================================

# --- Flask ---
FLASK_ENV=development
FLASK_PORT=5200
SECRET_KEY=change-me-to-a-random-string

# --- JWT Auth ---
JWT_SECRET=change-me-to-a-secure-random-key
JWT_EXPIRY_HOURS=24
JWT_ALGORITHM=HS256

# --- WeChat MiniApp ---
WECHAT_APPID=your-appid
WECHAT_APP_SECRET=your-app-secret
WECHAT_DEV_MODE=true

# --- Payment (see docs/COMMERCE_CLOSURE_STATUS.md) ---
# Dev default: stub upgrade enabled, WeChat order blocked
PAYMENT_STUB_MODE=true

# Production / real payment verification — set PAYMENT_STUB_MODE=false and fill all:
# WECHAT_MCHID=your-merchant-id
# WECHAT_API_V3_KEY=your-32-char-api-v3-key
# WECHAT_SERIAL_NO=your-cert-serial-no
# WECHAT_PRIVATE_KEY_PATH=/secure/apiclient_key.pem
# WECHAT_NOTIFY_URL=https://api.szbolent.com.cn/v1/payment/wechat/notify

# --- Enterprise sales webhook (optional) ---
# SALES_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# --- DeepSeek API ---
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# --- QCC (企查查) MCP — enterprise credit ---
# Authorization header value, including Bearer prefix
QCC_ENABLED=true
QCC_AUTH_TOKEN=

# --- ChromaDB ---
CHROMA_MODE=local
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=looma_knowledge

# --- SQLite ---
DATABASE_PATH=data/looma.db

# --- Poetry RAG (repo root data/poetry_full) ---
POETRY_CHROMA_PATH=../data/poetry_full
# auto | chroma | sqlite — production 2GB/容器建议 sqlite 或 auto+timeout
POETRY_SEARCH_MODE=auto
POETRY_CHROMA_SEARCH_TIMEOUT=10

# --- CORS (overseas: genz.ltd + www + tspace + api) ---
CORS_ORIGINS=https://genz.ltd,https://www.genz.ltd,https://tspace.genz.ltd,https://api.genz.ltd

# --- Quota ---
FREE_DAILY_LIMIT=30
SUPPORTER_DAILY_LIMIT=999999
PRO_DAILY_LIMIT=999999

# --- LLM Provider ---
# Overseas default: openai first, deepseek fallback, ollama local
LLM_PROVIDER_ORDER=openai,deepseek,ollama
OLLAMA_HOST=http://127.0.0.1:11434

# OpenAI (overseas primary)
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- API ---
API_REQUEST_TIMEOUT=90.0

# --- Google OAuth (overseas) ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback

# --- Stripe (overseas payment) ---
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_CURRENCY=USD

# --- PayPal (overseas payment) ---
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id

# --- Airwallex (overseas payment) ---
AIRWALLEX_API_KEY=your-airwallex-api-key
AIRWALLEX_CLIENT_KEY=your-airwallex-client-key
AIRWALLEX_MODE=demo
AIRWALLEX_WEBHOOK_SECRET=your-airwallex-webhook-secret

# --- Rate Limiting ---
RATE_LIMIT_GLOBAL=200/hour
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_PAYMENT=20/minute
# For production, use Redis: redis://redis:6379/1
RATE_LIMIT_STORAGE_URI=memory://

# --- Deployment Region ---
DEPLOY_REGION=US

# --- CloudBase (optional — see cloudbase/README.md) ---
CLOUDBASE_ENV_ID=your-cloudbase-env-id
