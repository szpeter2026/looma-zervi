# Copy to backend/.env (same as repo root .env.example)
#   cp .env.example .env
#
# ============================================
# Looma Backend Environment Configuration
# ============================================

# --- Flask ---
FLASK_ENV=development
FLASK_PORT=5200
SECRET_KEY=change-me-to-a-random-string

# --- JWT Auth ---
JWT_SECRET=change-me-to-a-secure-random-key
JWT_EXPIRY_HOURS=24
JWT_ALGORITHM=HS256

# --- WeChat MiniApp ---
WECHAT_APPID=your-appid
WECHAT_APP_SECRET=your-app-secret
WECHAT_DEV_MODE=true

# --- DeepSeek API ---
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# --- ChromaDB ---
CHROMA_MODE=local
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=looma_knowledge

# --- SQLite ---
DATABASE_PATH=data/looma.db

# --- Poetry RAG (repo root data/poetry_full) ---
POETRY_CHROMA_PATH=../data/poetry_full

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# --- Quota ---
FREE_DAILY_LIMIT=30
SUPPORTER_DAILY_LIMIT=999999
PRO_DAILY_LIMIT=999999

# --- LLM Provider ---
LLM_PROVIDER_ORDER=deepseek,ollama,openai
OLLAMA_HOST=http://127.0.0.1:11434

# --- API ---
API_REQUEST_TIMEOUT=90.0

# --- CloudBase (optional — see cloudbase/README.md) ---
CLOUDBASE_ENV_ID=your-cloudbase-env-id
